# PostgreSQL target used by the ELT pipeline and Streamlit dashboard.
DATABASE_URL=postgresql+psycopg2://ev_user:ev_password@localhost:5432/ev_charging

# Register for a token at https://ev.caltech.edu/register
# The ACN API uses the token as the HTTP basic-auth username with a blank password.
ACN_API_TOKEN=
ACN_SITE=caltech
ACN_START=2019-01-01
ACN_END=2020-12-31
ACN_MIN_ENERGY_KWH=0

# Optional offline mode: point to a JSON file exported from ACN-Data.
ACN_RAW_JSON=data/raw/acn_sessions_caltech.json

